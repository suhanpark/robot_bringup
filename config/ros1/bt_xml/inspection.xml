  <BehaviorTree ID="inspection">
    <Inverter>
      <KeepRunningUntilFailure>
        <Inverter>
          <Inspection/>
        </Inverter>
      </KeepRunningUntilFailure>
    </Inverter>
  </BehaviorTree>
</root>